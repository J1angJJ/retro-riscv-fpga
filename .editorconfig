root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,txt,rst}]
trim_trailing_whitespace = false

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{sv,svh,v,vd,vh,vhdl,vhd,tcl,sdc,xdc}]
indent_size = 4

[Makefile]
indent_style = tab

[*.{bat,cmd,ps1}]
end_of_line = crlf
