// Tang Nano 20K SparrowRV constraints.
// UART pins target the BL616 serial bridge path used by the board console.

IO_LOC "clk_27m" 4;
IO_PORT "clk_27m" IO_TYPE=LVCMOS33 PULL_MODE=UP;

IO_LOC "rst_n" 88;
IO_PORT "rst_n" IO_TYPE=LVCMOS33 PULL_MODE=UP;

IO_LOC "led0_n" 15;
IO_PORT "led0_n" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8;

IO_LOC "uart_tx" 69;
IO_PORT "uart_tx" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8;

IO_LOC "uart_rx" 70;
IO_PORT "uart_rx" IO_TYPE=LVCMOS33 PULL_MODE=UP;
